generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Usuarios ─────────────────────────────────────────────────────────────────
model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  rol       Rol      @default(ADMIN)
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calculos  Calculo[]

  @@map("usuarios")
}

// ─── Configuración del negocio ─────────────────────────────────────────────────
model ConfigNegocio {
  id          Int      @id @default(autoincrement())
  clave       String   @unique @db.VarChar(100)
  valor       String   @db.Text
  updatedAt   DateTime @updatedAt

  @@map("config_negocio")
}

// ─── Costos Fijos Mensuales ────────────────────────────────────────────────────
model CostoFijo {
  id            Int      @id @default(autoincrement())
  mes           Int      // 1-12
  anio          Int
  alquiler      Decimal  @default(0) @db.Decimal(10, 2)
  electricidad  Decimal  @default(0) @db.Decimal(10, 2)
  salarios      Decimal  @default(0) @db.Decimal(10, 2)
  internet      Decimal  @default(0) @db.Decimal(10, 2)
  agua          Decimal  @default(0) @db.Decimal(10, 2)
  transporte    Decimal  @default(0) @db.Decimal(10, 2)
  otros         Decimal  @default(0) @db.Decimal(10, 2)
  horasMes      Int      @default(160)
  piezasMes     Int      @default(200)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([mes, anio])
  @@map("costos_fijos")
}

// ─── Categorías de Productos ──────────────────────────────────────────────────
model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique @db.VarChar(100)
  icono     String?    @db.VarChar(50)
  color     String?    @db.VarChar(20)
  activo    Boolean    @default(true)
  orden     Int        @default(0)
  createdAt DateTime   @default(now())

  productos Producto[]

  @@map("categorias")
}

// ─── Productos del negocio ─────────────────────────────────────────────────────
model Producto {
  id             Int       @id @default(autoincrement())
  nombre         String    @db.VarChar(150)
  categoriaId    Int
  descripcion    String?   @db.Text
  costoInsumo    Decimal   @default(0) @db.Decimal(10, 2)
  costoPapel     Decimal   @default(0) @db.Decimal(10, 2)
  costoTinta     Decimal   @default(0) @db.Decimal(10, 2)
  costoElectrico Decimal   @default(0) @db.Decimal(10, 2)
  costoFijoPieza Decimal   @default(0) @db.Decimal(10, 2)
  costoTotal     Decimal   @default(0) @db.Decimal(10, 2)
  precioMinimo   Decimal   @default(0) @db.Decimal(10, 2)
  precioSugerido Decimal   @default(0) @db.Decimal(10, 2)
  margen         Decimal   @default(30) @db.Decimal(5, 2)
  activo         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  categoria      Categoria    @relation(fields: [categoriaId], references: [id])
  calculos       Calculo[]
  pedidoItems    PedidoItem[]

  @@map("productos")
}

// ─── Base de Datos de Tiempos y Temperaturas ──────────────────────────────────
model ProductoSublimable {
  id          Int     @id @default(autoincrement())
  nombre      String  @db.VarChar(150)
  categoria   String  @db.VarChar(100)
  tempC       Int
  tempF       Int
  tiempoSeg   Int
  presion     String  @db.VarChar(50)  // BAJA, MEDIA, ALTA
  notas       String? @db.Text
  activo      Boolean @default(true)

  @@map("productos_sublimables")
}

// ─── Historial de Cálculos ────────────────────────────────────────────────────
model Calculo {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  productoId Int?
  nombreCalc String   @db.VarChar(150)
  datos      Json     // Inputs del cálculo
  resultado  Json     // Outputs calculados
  createdAt  DateTime @default(now())

  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  producto   Producto? @relation(fields: [productoId], references: [id])

  @@map("calculos")
}

// ─── Logs del sistema ─────────────────────────────────────────────────────────
model Log {
  id        Int      @id @default(autoincrement())
  nivel     NivelLog
  modulo    String   @db.VarChar(50)
  mensaje   String   @db.Text
  meta      Json?
  createdAt DateTime @default(now())

  @@map("logs")
  @@index([nivel])
  @@index([createdAt])
}

// ─── Insumos / Inventario ─────────────────────────────────────────────────────
model Insumo {
  id               Int      @id @default(autoincrement())
  nombre           String   @db.VarChar(150)
  tipo             String   @db.VarChar(50) // BLANK, PAPEL, TINTA, EMPAQUE, OTRO
  cantidadComprada Int      @default(1)
  costoTotal       Decimal  @db.Decimal(10, 2)
  costoUnitario    Decimal  @db.Decimal(10, 4)
  proveedor        String?  @db.VarChar(100)
  stockActual      Int      @default(0)
  activo           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("insumos")
}

// ─── Clientes (CRM) ───────────────────────────────────────────────────────────
model Cliente {
  id                 Int      @id @default(autoincrement())
  identificacion     String   @unique @db.VarChar(20)
  tipoIdentificacion String   @default("CEDULA") @db.VarChar(20) // CEDULA, RUC, PASAPORTE
  nombre             String   @db.VarChar(150)
  email              String?  @db.VarChar(150)
  telefono           String?  @db.VarChar(20)
  direccion          String?  @db.Text
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  pedidos            Pedido[]

  @@map("clientes")
}

// ─── Pedidos / Cotizaciones ───────────────────────────────────────────────────
model Pedido {
  id          Int      @id @default(autoincrement())
  numero      String   @unique @db.VarChar(20) // ej: PED-00001
  clienteId   Int
  estado      String   @default("COTIZACION") @db.VarChar(50) // COTIZACION, IMPRIMIENDO, PLANCHANDO, LISTO, ENTREGADO
  formaPago   String   @default("01") @db.VarChar(2) // SRI code (01: Efectivo, 16: Debito, 19: Credito, 20: Transferencia)
  subtotal    Decimal  @default(0) @db.Decimal(10, 2)
  iva         Decimal  @default(0) @db.Decimal(10, 2)
  descuento   Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @default(0) @db.Decimal(10, 2)
  notas       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  items       PedidoItem[]
  facturaSRI  FacturaSRI?

  @@map("pedidos")
}

model PedidoItem {
  id             Int      @id @default(autoincrement())
  pedidoId       Int
  productoId     Int
  cantidad       Int      @default(1)
  precioUnitario Decimal  @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)

  pedido         Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("pedido_items")
}

// ─── Enums ────────────────────────────────────────────────────────────────────
enum Rol {
  SUPERADMIN
  ADMIN
  USER
}

enum NivelLog {
  INFO
  WARN
  ERROR
  SECURITY
  AUDIT
}

// ─── Factura SRI y Emisor (Ecuador) ───────────────────────────────────────────
model EmisorSRI {
  id                    Int      @id @default(1)
  ruc                   String   @db.VarChar(13)
  razonSocial           String   @db.VarChar(150)
  nombreComercial       String?  @db.VarChar(150)
  dirMatriz             String   @db.Text
  dirEstablecimiento    String   @db.Text
  codigoEstablecimiento String   @default("001") @db.VarChar(3)
  codigoPuntoEmision    String   @default("001") @db.VarChar(3)
  obligadoContabilidad  Boolean  @default(false)
  ambiente              Int      @default(1) // 1 = Pruebas, 2 = Producción
  passwordFirma         String   @db.VarChar(255)
  rutaFirma             String   @db.VarChar(255) // ruta del archivo .p12 local
  contribuyenteEspecial String?  @db.VarChar(50)
  agenteRetencion       String?  @db.VarChar(50)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("emisor_sri")
}

model FacturaSRI {
  id                 Int      @id @default(autoincrement())
  pedidoId           Int      @unique
  claveAcceso        String   @unique @db.VarChar(100)
  numeroAutorizacion String?  @db.VarChar(100)
  estado             String   @db.VarChar(50) // DEVUELTA, RECHAZADA, AUTORIZADA, PENDIENTE
  mensajeError       String?  @db.Text
  xmlFirmado         String?  @db.LongText
  fechaAutorizacion  DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  pedido             Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("facturas_sri")
}
